Smallest window containing 0, 1 and 2
Difficulty: EasyAccuracy: 49.73%Submissions: 69K+Points: 2
Given a string s consisting only of the characters '0', '1' and '2', determine the length of the smallest substring that contains all three characters at least once.

If no such substring exists, return -1.

Examples :

Input: s = "10212"
Output: 3
Explanation: The substring "102" is the shortest substring that contains all three characters '0', '1', and '2', so the answer is 3.
Input: s = "12121"
Output: -1
Explanation: The character '0' is not present in the string, so no substring can contain all three characters '0', '1', and '2'. Hence, the answer is -1.
Constraints:
1 ≤ s.size() ≤ 105

JAVA-
class Solution {
    public int smallestSubstring(String s) {
       int n = s.length();
       int ans = Integer.MAX_VALUE;
       int start = 0;
       int end = 0;
       HashMap<Character, Integer> map = new HashMap<>();
     
       while(end < n)
       {
            map.put(s.charAt(end), map.getOrDefault(s.charAt(end), 0) + 1);
         while(start < end && map.size() == 3)
         { ans = Math.min(ans, end - start + 1);
             map.put(s.charAt(start), map.get(s.charAt(start)) - 1);
             if(map.get(s.charAt(start)) <= 0)
             {
                 map.remove(s.charAt(start));
             }
             start++;
         }
        
         end++;
         
       }
       if(ans == Integer.MAX_VALUE)
       {
           return -1;
       }
       return ans;
        
    }
};

PYTHON-
class Solution:
    def smallestSubstring(self, s):
        n = len(s)
        start = 0
        end = 0
        ans = float('inf')
        map = {}
        while end < n:
            map[s[end]] = map.get(s[end], 0) + 1
            while start <= end and len(map) == 3:
                ans = min(ans, end - start + 1)
                c = s[start]
                map[c] = map[c] - 1
                if map[c] == 0:
                    del map[c]
                start = start + 1
            end = end + 1
        if ans == float('inf'):
            return -1
        return ans
    

