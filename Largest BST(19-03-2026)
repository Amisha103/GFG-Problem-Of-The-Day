class Details:
    def __init__(self, min, max, size):
        self.min = min
        self.max = max
        self.size = size


class Solution:
    def dfs(self, node):
        if not node:
            return Details(float('inf'), float('-inf'), 0)
        
        left = self.dfs(node.left)
        right = self.dfs(node.right)
        
        if left.max < node.data and right.min > node.data:
            size = 1 + left.size + right.size
            self.maxSize = max(self.maxSize, size)
            min_val = min(node.data, left.min)
            max_val = max(node.data, right.max)
            return  Details(min_val, max_val, size)
        
        return Details(float('-inf'), float('inf'), 0)
        
    def largestBst(self, root):
        self.maxSize = 0
        self.dfs(root)
        return self.maxSize
    

        
