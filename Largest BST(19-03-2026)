   static Details dfs(Node node)
    {
        if(node == null)
        {
            return new Details(Integer.MAX_VALUE, Integer.MIN_VALUE, 0);
            
        }
        Details left = dfs(node.left);
        Details right = dfs(node.right);
        
        if(left.max < node.data && node.data < right.min)
        {
            int size = 1 + left.size + right.size;
            maxSize = Math.max(maxSize, size);
            int min = Math.min(node.data, left.min);
            int max = Math.max(node.data, right.max);
            return new Details(min, max, size);
        }
        
        return new Details(Integer.MIN_VALUE, Integer.MAX_VALUE, 0);
      
    }
