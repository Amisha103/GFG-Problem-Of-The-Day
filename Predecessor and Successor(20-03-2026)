class Solution {
    public ArrayList<Node> findPreSuc(Node root, int key) {
       int minEle = Integer.MIN_VALUE;
       Node min = null;
       Node max = null;
       int maxEle = Integer.MAX_VALUE;
       Queue<Node> q = new LinkedList<>();
       q.add(root);
       while(!q.isEmpty())
       {
           int n = q.size();
           for(int i = 0;i < n;i++)
           {
              Node curr = q.poll();
              int data = curr.data;
              if(data < key)
              {
                  if(minEle < data)
                  {
                      minEle = data;
                      min = curr;
                  }
              }
              
              if(data > key)
              {
                  if(maxEle > data)
                  {
                      maxEle = data;
                      max = curr;
                  }
              }
              Node left = curr.left;
              Node right = curr.right;
              if(left != null)
              {
                  q.add(left);
              }
              if(right != null)
              {
                  q.add(right);
              }
           }
           
       }
       
        ArrayList<Node> ans = new ArrayList<>();
        ans.add(min);
        ans.add(max);
        return ans;
    }
}



