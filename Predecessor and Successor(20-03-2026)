class Solution:
    def findPreSuc(self, root, key):
        que = []
        minEle = float('-inf')
        maxEle = float('inf')
        mini = None
        maxi = None
        que.append(root)
        while que:
            n = len(que)
            for i in range(0, n):
                cur = que.pop(0)
                if cur.data < key:
                    if minEle < cur.data:
                        minEle = cur.data
                        mini = cur
                if cur.data > key:
                    if maxEle > cur.data:
                        maxEle = cur.data
                        maxi = cur
                
                if cur.left:
                    que.append(cur.left)
                if cur.right:
                    que.append(cur.right)
        ans = [mini, maxi]
        return ans
                        
        
