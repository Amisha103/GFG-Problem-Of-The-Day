Huffman Encoding
Difficulty: HardAccuracy: 32.4%Submissions: 75K+Points: 8Average Time: 30m
Given a string s of distinct characters and their corresponding frequency f[ ] i.e. character s[i] has f[i] frequency. You need to build the Huffman tree and return all the huffman codes in preorder traversal of the tree.
Note: While merging if two nodes have the same value, then the node which occurs at first will be taken on the left of Binary Tree and the other one to the right, otherwise Node with less value will be taken on the left of the subtree and other one to the right.

Examples:

Input: s = "abcdef", f[] = {5, 9, 12, 13, 16, 45}
Output: [0, 100, 101, 1100, 1101, 111]
Explanation:

HuffmanCodes will be:
f : 0
c : 100
d : 101
a : 1100
b : 1101
e : 111
Constraints:
1 ≤ s.size() = f.size() ≤ 26

JAVA-
class Node {
    char ch;
    int freq;
    int index;
    Node left, right;

  
    Node(char ch, int freq, int index) {
        this.ch = ch;
        this.freq = freq;
        this.index = index;
    }

  
    Node(int freq, Node left, Node right, int index) {
        this.ch = '\0'; 
        this.freq = freq;
        this.left = left;
        this.right = right;
        this.index = index; 
    }
}

class Solution {
    public ArrayList<String> huffmanCodes(String s, int f[]) {
        int n = s.length();

       
        if (n == 1) {
            ArrayList<String> codes = new ArrayList<>();
            codes.add("0");
            return codes;
        }

    
        PriorityQueue<Node> pq = new PriorityQueue<>(
            (a, b) -> a.freq == b.freq ? a.index - b.index : a.freq - b.freq
        );

        for (int i = 0; i < n; i++) {
            pq.add(new Node(s.charAt(i), f[i], i));
        }

      
        while (pq.size() > 1) {
            Node left = pq.poll();
            Node right = pq.poll();
           
            Node parent = new Node(left.freq + right.freq, left, right, Math.min(left.index, right.index));
            pq.add(parent);
        }

        Node root = pq.poll();
        ArrayList<String> codes = new ArrayList<>();
        preorder(root, "", codes);
        return codes;
    }
    
    private void preorder(Node node, String code, ArrayList<String> codes) {
        if (node == null) return;
        if (node.ch != '\0') { 
            codes.add(code);
        }
        preorder(node.left, code + "0", codes);
        preorder(node.right, code + "1", codes);
    }
}

