Minimum Cost to Fill Given Weight
Difficulty: MediumAccuracy: 25.56%Submissions: 81K+Points: 4
Given a bag of size w kg and you are provided costs of packets different weights of oranges in array cost[], find the minimum total cost to buy exactly w kg oranges

The cost of 1 kg orange is present at index 0 and in general arr[i] has cost of (i+1) kg orange.
cost[i] = -1 means that 'i+1' kg packet of orange is unavailable.
If it is not possible to buy exactly w kg oranges then return -1. It may be assumed that there is an infinite supply of all available packet types.
Examples:

Input: cost[] = [20, 10, 4, 50, 100], w = 5
Output: 14
Explanation: The minimum cost is 14 by purchasing a 2kg packet for 10 and a 3kg packet for 4.
Input: cost[] = [-1, -1, 4, 3, -1], w = 5
Output: -1
Explanation: It is not possible to buy 5 kgs.
Constraints:
1 ≤ cost.size(), w ≤ 2*103
1 ≤ cost[i] ≤ 105


JAVA-
class Solution {
    public int minimumCost(int[] cost, int w) {
    int ans = find(0, w, cost, new int[cost.length + 1][w + 1]);
    if(ans == Integer.MAX_VALUE) return -1;
    return ans;
    }
    int find(int ind, int w, int cost[], int dp[][])
    {
        if(w == 0)
        {
            return 0;
        }
        if(w < 0 || ind == cost.length)
        {
            return Integer.MAX_VALUE;
        }
        if(dp[ind][w] != 0)
        {
            return dp[ind][w];
        }
        if(cost[ind] == -1) return dp[ind][w] = find(ind+1,w,cost, dp);
        int take = find(ind, w - (ind + 1), cost, dp);
        if(take != Integer.MAX_VALUE)
        {
            take = take + cost[ind];
        }
        int nTake = find(ind + 1, w, cost, dp);
        
        return dp[ind][w] = Math.min(take, nTake);
    }
}

PYTHON-
class Solution:

    def find(self, ind, w, cost, dp):

        if w == 0:
            return 0

        if w < 0 or ind == len(cost):
            return float('inf')

        if dp[ind][w] != 0:
            return dp[ind][w]

        if cost[ind] == -1:
            dp[ind][w] = self.find(ind + 1, w, cost, dp)
            return dp[ind][w]


        take = self.find(ind, w - (ind + 1), cost, dp)

        if take != float('inf'):
            take += cost[ind]


        nTake = self.find(ind + 1, w, cost, dp)


        dp[ind][w] = min(take, nTake)

        return dp[ind][w]


    def minimumCost(self, cost, w):

        dp = [[0]*(w+1) for _ in range(len(cost))]

        ans = self.find(0, w, cost, dp)

        if ans == float('inf'):
            return -1

        return ans
